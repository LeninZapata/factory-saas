        {
          "type": "group",
          "columns": 2,
          "gap": "normal",
          "fields": [
            {
              "name": "categoria",
              "label": "Categoría",
              "type": "select",
              "options": [
                {
                  "value": "general",
                  "label": "General"
                },
                {
                  "value": "tecnico",
                  "label": "Técnico"
                },
                {
                  "value": "facturacion",
                  "label": "Facturación"
                },
                {
                  "value": "soporte",
                  "label": "Soporte"
                }
              ]
            },
            {
              "name": "orden",
              "label": "Orden de visualización",
              "type": "number",
              "placeholder": "1",
              "min": 1
            }
          ]
        }
      ]
    },
