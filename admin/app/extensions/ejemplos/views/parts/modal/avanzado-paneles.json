[
  {
    "type": "html",
    "content": "<h4 style='margin-bottom:8px'>Paneles</h4><p class='text-muted' style='margin-bottom:24px'>Un panel es el mismo modal pero anclado a un borde de la pantalla: aparece deslizándose desde ese lado. Ideal para filtros, detalles, configuraciones y drawers tipo mobile.</p>"
  },
  {
    "type": "section",
    "title": "Posiciones",
    "description": "Cuatro direcciones disponibles con la opción <code>panel</code>: <code>'right'</code> (defecto), <code>'left'</code>, <code>'top'</code> y <code>'bottom'</code>.",
    "content": [
      {
        "type": "html",
        "content": "<div style='display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px'><button class='btn btn-primary' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>Panel desde la derecha. Útil para detalles, configuraciones y formularios laterales.</p>', { html: true, title: '→ Panel derecha', panel: 'right' })\">Desde la derecha</button><button class='btn btn-secondary' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>Panel desde la izquierda. Útil para menús, índices y navegación secundaria.</p>', { html: true, title: '← Panel izquierda', panel: 'left' })\">Desde la izquierda</button><button class='btn btn-outline-primary' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>Panel desde arriba. Útil para alertas, búsquedas globales y banners interactivos.</p>', { html: true, title: '↑ Panel arriba', panel: 'top' })\">Desde arriba</button><button class='btn btn-outline-secondary' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>Panel desde abajo. Patrón tipo drawer mobile para acciones rápidas o formularios cortos.</p>', { html: true, title: '↓ Panel abajo', panel: 'bottom' })\">Desde abajo</button></div>"
      },
      {
        "type": "code",
        "lang": "javascript",
        "content": "// Panel desde la derecha (por defecto)\nogComponent('modal').open(resource, { panel: 'right', title: 'Filtros' });\n\n// Panel desde la izquierda\nogComponent('modal').open(resource, { panel: 'left', title: 'Navegación' });\n\n// Drawer desde abajo (estilo mobile)\nogComponent('modal').open(resource, { panel: 'bottom', title: 'Acciones' });\n\n// Panel desde arriba\nogComponent('modal').open(resource, { panel: 'top', title: 'Búsqueda' });"
      }
    ]
  },
  {
    "type": "section",
    "title": "Tamaños",
    "description": "Con <code>panelSize</code> controlas el <strong>ancho</strong> en todos los paneles: laterales (right/left) y horizontales (top/bottom). Los paneles que no ocupan el ancho completo se centran automáticamente en su eje. Valores: <code>'sm'</code>, <code>'md'</code> (defecto), <code>'lg'</code>, <code>'full'</code>.",
    "content": [
      {
        "type": "html",
        "content": "<div style='display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:8px'><div><div style='margin-bottom:8px;font-size:13px;color:#6c757d;font-weight:600'>→ Derecha — ancho</div><div style='display:flex;gap:8px;flex-wrap:wrap'><button class='btn btn-outline-primary btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>300px de ancho.</p>', { html: true, title: '→ sm · 300px', panel: 'right', panelSize: 'sm' })\">sm</button><button class='btn btn-primary btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>440px de ancho (default).</p>', { html: true, title: '→ md · 440px', panel: 'right', panelSize: 'md' })\">md</button><button class='btn btn-outline-primary btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>640px de ancho.</p>', { html: true, title: '→ lg · 640px', panel: 'right', panelSize: 'lg' })\">lg</button><button class='btn btn-outline-danger btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>Ancho completo.</p>', { html: true, title: '→ full', panel: 'right', panelSize: 'full' })\">full</button></div></div><div><div style='margin-bottom:8px;font-size:13px;color:#6c757d;font-weight:600'>← Izquierda — ancho</div><div style='display:flex;gap:8px;flex-wrap:wrap'><button class='btn btn-outline-secondary btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>300px de ancho.</p>', { html: true, title: '← sm · 300px', panel: 'left', panelSize: 'sm' })\">sm</button><button class='btn btn-secondary btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>440px de ancho (default).</p>', { html: true, title: '← md · 440px', panel: 'left', panelSize: 'md' })\">md</button><button class='btn btn-outline-secondary btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>640px de ancho.</p>', { html: true, title: '← lg · 640px', panel: 'left', panelSize: 'lg' })\">lg</button><button class='btn btn-outline-danger btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>Ancho completo.</p>', { html: true, title: '← full', panel: 'left', panelSize: 'full' })\">full</button></div></div><div><div style='margin-bottom:8px;font-size:13px;color:#6c757d;font-weight:600'>↑ Arriba — ancho (centrado)</div><div style='display:flex;gap:8px;flex-wrap:wrap'><button class='btn btn-outline-info btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>300px de ancho, centrado horizontalmente.</p>', { html: true, title: '↑ sm · 300px', panel: 'top', panelSize: 'sm' })\">sm</button><button class='btn btn-info btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>440px de ancho (default).</p>', { html: true, title: '↑ md · 440px', panel: 'top', panelSize: 'md' })\">md</button><button class='btn btn-outline-info btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>640px de ancho.</p>', { html: true, title: '↑ lg · 640px', panel: 'top', panelSize: 'lg' })\">lg</button><button class='btn btn-outline-danger btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>Ancho completo.</p>', { html: true, title: '↑ full', panel: 'top', panelSize: 'full' })\">full</button></div></div><div><div style='margin-bottom:8px;font-size:13px;color:#6c757d;font-weight:600'>↓ Abajo — ancho (centrado)</div><div style='display:flex;gap:8px;flex-wrap:wrap'><button class='btn btn-outline-warning btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>300px de ancho, centrado horizontalmente.</p>', { html: true, title: '↓ sm · 300px', panel: 'bottom', panelSize: 'sm' })\">sm</button><button class='btn btn-warning btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>440px de ancho (default).</p>', { html: true, title: '↓ md · 440px', panel: 'bottom', panelSize: 'md' })\">md</button><button class='btn btn-outline-warning btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>640px de ancho.</p>', { html: true, title: '↓ lg · 640px', panel: 'bottom', panelSize: 'lg' })\">lg</button><button class='btn btn-outline-danger btn-sm' onclick=\"ogComponent('modal').open('<p style=\\'padding:12px\\'>Ancho completo.</p>', { html: true, title: '↓ full', panel: 'bottom', panelSize: 'full' })\">full</button></div></div></div>"
      },
      {
        "type": "code",
        "lang": "javascript",
        "content": "// Todos los paneles: panelSize controla el ANCHO\n// Laterales (right/left): se anclan al borde, alto = 100%\nogComponent('modal').open(resource, { panel: 'right', panelSize: 'sm' });  // 300px\nogComponent('modal').open(resource, { panel: 'right', panelSize: 'md' });  // 440px (default)\nogComponent('modal').open(resource, { panel: 'right', panelSize: 'lg' });  // 640px\nogComponent('modal').open(resource, { panel: 'right', panelSize: 'full' }); // 100%\n\n// Horizontales (top/bottom): se centran horizontalmente\nogComponent('modal').open(resource, { panel: 'bottom', panelSize: 'sm' });  // 300px, centrado\nogComponent('modal').open(resource, { panel: 'bottom', panelSize: 'md' });  // 440px, centrado\nogComponent('modal').open(resource, { panel: 'bottom', panelSize: 'full' }); // 100%"
      }
    ]
  }
]