  {
    "type": "html",
    "content": "<h4 class='og-mt-4'>Ejemplos de Configuración</h4>"
  },
  {
    "type": "component",
    "component": "widget",
    "config": {
      "columns": 2,
      "widgets": [
        {
          "title": "📖 Cargar Formulario",
          "order": 1,
          "html": "<div style='padding:1.5rem;'><p style='color:#666;margin-bottom:1rem;'>Para cargar un formulario:</p><pre style='background:#f5f5f5;padding:1rem;border-radius:4px;font-size:0.85rem;'>{<br>  \"title\": \"Mi Formulario\",<br>  \"form\": \"plugin/formularios/mi-form\"<br>}</pre><p style='margin-top:1rem;color:#666;font-size:0.9rem;'>El sistema agrega /forms/ automáticamente.</p></div>"
        },
        {
          "title": "📖 Cargar Vista",
          "order": 2,
          "html": "<div style='padding:1.5rem;'><p style='color:#666;margin-bottom:1rem;'>Para cargar una vista:</p><pre style='background:#f5f5f5;padding:1rem;border-radius:4px;font-size:0.85rem;'>{<br>  \"title\": \"Mi Vista\",<br>  \"view\": \"plugin/sections/mi-vista\"<br>}</pre><p style='margin-top:1rem;color:#666;font-size:0.9rem;'>La vista se carga directamente.</p></div>"
        },
        {
          "title": "📖 Componente Anidado",
          "order": 3,
          "html": "<div style='padding:1.5rem;'><p style='color:#666;margin-bottom:1rem;'>Para anidar componente:</p><pre style='background:#f5f5f5;padding:1rem;border-radius:4px;font-size:0.85rem;'>{<br>  \"title\": \"DataTable\",<br>  \"component\": \"datatable\",<br>  \"config\": {...}<br>}</pre><p style='margin-top:1rem;color:#666;font-size:0.9rem;'>Puedes anidar cualquier componente.</p></div>"
        },
        {
          "title": "💡 Mini Dashboard",
          "order": 4,
          "html": "<div style='padding:1.5rem;'><div style='display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;'><div style='background:#e0f2fe;padding:1rem;border-radius:6px;text-align:center;'><div style='font-size:2rem;'>🎯</div><strong style='color:#0284c7;'>95%</strong></div><div style='background:#dcfce7;padding:1rem;border-radius:6px;text-align:center;'><div style='font-size:2rem;'>📈</div><strong style='color:#16a34a;'>+23%</strong></div></div></div>"
        }
      ]
    }
  }
]