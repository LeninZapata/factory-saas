    "component": "widget",
    "config": {
      "columns": 2,
      "widgets": [
        {
          "title": "🔔 Notificaciones",
          "order": 1,
          "html": "<div style='padding:1.5rem;'><p style='margin:0 0 1rem;color:#666;'>Tienes 5 notificaciones pendientes.</p><button class='btn btn-primary' onclick='ogModal.open(\"Notificaciones\", {title: \"Notificaciones Recientes\", html: \"<div style=\\\"padding:1.5rem;\\\"><h4>📬 Nueva Notificación</h4><p>Usuario <strong>Juan Pérez</strong> comentó.</p><hr><h4>✅ Tarea Completada</h4><p>El reporte ha sido generado.</p></div>\"});'>Ver Notificaciones</button></div>"
        },
        {
          "title": "📝 Crear Tarea",
          "order": 2,
          "html": "<div style='padding:1.5rem;'><p style='margin:0 0 1rem;color:#666;'>Gestiona tus tareas pendientes.</p><button class='btn btn-success' onclick='ogModal.open(\"Nueva Tarea\", {title: \"Nueva Tarea\", html: \"<div style=\\\"padding:1.5rem;\\\"><div style=\\\"margin-bottom:1rem;\\\"><label>Título</label><input type=\\\"text\\\" placeholder=\\\"Ej: Revisar reportes\\\" style=\\\"width:100%;padding:0.5rem;border:1px solid #ddd;border-radius:4px;\\\"></div><div style=\\\"margin-bottom:1rem;\\\"><label>Descripción</label><textarea style=\\\"width:100%;padding:0.5rem;border:1px solid #ddd;border-radius:4px;min-height:80px;\\\"></textarea></div><button class=\\\"btn btn-primary\\\" id=\\\"saveTaskBtn\\\">Guardar</button></div>\"});setTimeout(function(){document.getElementById(\"saveTaskBtn\").onclick=function(){ogToast.success(\"Guardado\");modal.closeAll();};},100);'>Nueva Tarea</button></div>"
        },
        {
          "title": "👤 Perfil",
          "order": 3,
          "html": "<div style='padding:1.5rem;text-align:center;'><div style='width:80px;height:80px;margin:0 auto 1rem;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:2rem;'>👤</div><h4 style='margin:0 0 0.5rem;'>Juan Pérez</h4><p style='margin:0 0 1rem;color:#666;font-size:0.9rem;'>admin@empresa.com</p><button class='btn btn-secondary' onclick='ogModal.open(\"Perfil\", {title: \"Perfil de Usuario\", html: \"<div style=\\\"padding:2rem;text-align:center;\\\"><div style=\\\"width:120px;height:120px;margin:0 auto 1rem;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:3rem;\\\">👤</div><h3>Juan Pérez</h3><p>Administrador del Sistema</p><div style=\\\"background:#f8f9fa;padding:1rem;border-radius:6px;margin:1rem 0;\\\"><strong>Email:</strong> admin@empresa.com</div></div>\"});'>Ver Perfil</button></div>"
        },
        {
          "title": "📊 Reporte",
          "order": 4,
          "html": "<div style='padding:1.5rem;'><p style='margin:0 0 1rem;color:#666;'>Genera reportes personalizados.</p><button class='btn btn-primary' onclick='ogModal.open(\"Reporte\", {title: \"Generar Reporte\", html: \"<div style=\\\"padding:1.5rem;\\\"><p style=\\\"margin-bottom:1.5rem;\\\">Selecciona las opciones:</p><div style=\\\"margin-bottom:1rem;\\\"><label>Mes</label><select style=\\\"width:100%;padding:0.5rem;border:1px solid #ddd;border-radius:4px;\\\"><option>Enero 2025</option><option>Febrero 2025</option></select></div><button class=\\\"btn btn-success\\\" id=\\\"generateReportBtn\\\">Generar</button></div>\"});setTimeout(function(){document.getElementById(\"generateReportBtn\").onclick=function(){ogToast.success(\"Reporte generado\");modal.closeAll();};},100);'>Generar Reporte</button></div>"
        }
      ]
    }
  }
