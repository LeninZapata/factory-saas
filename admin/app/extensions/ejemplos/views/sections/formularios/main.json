    {
      "id": "modales",
      "title": "🪟 Modales",
      "content": [
        {
          "type": "html",
          "content": "<h3>Formularios en Modal</h3><p>Abre formularios en ventanas emergentes:</p><div style='display: flex; gap: 1rem; margin: 1rem 0;'><button class='btn btn-primary' onclick='ogModal.open(\"ejemplos|forms/formularios/form-modal-login\", { title: \"Login\" })'>🔐 Login</button><button class='btn btn-success' onclick='ogModal.open(\"ejemplos|forms/formularios/form-modal-login\", { title: \"🎯 Login con Focus\" })'>🎯 Focus</button><button class='btn btn-primary' onclick='ogModal.open(\"ejemplos|forms/formularios/form-modal-register\", { title: \"Registro\" })'>📝 Registro</button></div><h4 style='margin-top: 2rem;'>Código de ejemplo:</h4><pre style='background: #f5f5f5; padding: 1rem; border-radius: 0.5rem; overflow-x: auto;'>ogModal.open(\"ejemplos|forms/formularios/form-modal-login\", {\n  title: \"Login\",\n  width: \"500px\"\n});</pre><h4 style='margin-top: 2rem;'>✨ Ejemplo con Autofocus:</h4><pre style='background: #f5f5f5; padding: 1rem; border-radius: 0.5rem; overflow-x: auto;'>// En el JSON del formulario:\n{\n  \"name\": \"email\",\n  \"type\": \"email\",\n  \"focus\": true  // ← El cursor va aquí automáticamente\n}</pre>"
        }
      ]
    }
